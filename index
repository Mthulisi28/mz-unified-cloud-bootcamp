<!DOCTYPE html>
<html>
<head>
  <title>MZ Bootcamp LMS</title>

  <style>
    body{
      background:#0b1220;
      color:white;
      font-family:Arial;
      padding:40px;
    }

    .session{
      background:#111827;
      padding:20px;
      margin-bottom:10px;
      cursor:pointer;
      border-radius:8px;
    }

    .session:hover{
      background:#1f2937;
    }

    #viewer{
      margin-top:30px;
      padding:20px;
      background:#111827;
      border-radius:8px;
    }
  </style>
</head>

<body>

<h1>MZ Unified Cloud Bootcamp</h1>

<div class="session" onclick="showSession(1)">
  Session 1 - Cloud Foundations
</div>

<div class="session" onclick="showSession(2)">
  Session 2 - IAM
</div>

<div id="viewer">
  Select a session
</div>

<script>

function showSession(id){

  const viewer =
    document.getElementById("viewer");

  if(id === 1){
    viewer.innerHTML =
      "<h2>Cloud Foundations</h2><p>Introduction to AWS Cloud.</p>";
  }

  if(id === 2){
    viewer.innerHTML =
      "<h2>IAM</h2><p>Identity and Access Management.</p>";
  }
}

</script>

</body>
</html>